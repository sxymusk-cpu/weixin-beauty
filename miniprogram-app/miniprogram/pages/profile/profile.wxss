/* 栀·美研所 — 我的 */
.page { position: relative; height: 100vh; background: var(--bg-page); }

.nav { position: fixed; top: 0; left: 0; right: 0; background: var(--bg-page); z-index: 100; }
.nav-inner { height: 44px; display: flex; align-items: center; padding: 0 32rpx; }
.nav-title { font-size: 36rpx; font-weight: 700; color: var(--ink-900); }

.scroll-area { position: absolute; bottom: 0; left: 0; right: 0; }

/* 用户卡 */
.user-card {
  margin: 24rpx 32rpx 0;
  background: linear-gradient(160deg, #fff 0%, #ece4f7 100%);
  border-radius: 36rpx;
  padding: 32rpx 28rpx;
  box-shadow: var(--sh-2);
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar-wrap {
  width: 96rpx; height: 96rpx;
  border-radius: 50%;
  background: var(--violet-500);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}

.avatar-text { font-size: 44rpx; color: #fff; font-weight: 700; }

.user-info { flex: 1; min-width: 0; }
.user-name { display: block; font-size: 34rpx; font-weight: 700; color: var(--ink-900); }
.user-sub  { display: block; font-size: 22rpx; color: var(--ink-500); margin-top: 6rpx; }

.login-btn {
  flex-shrink: 0;
  background: var(--violet-500);
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  padding: 16rpx 32rpx;
  border-radius: 999rpx;
}

/* VIP 卡 */
.vip-card {
  margin: 20rpx 32rpx 0;
  background: linear-gradient(135deg, #33225C 0%, #5A3F8A 100%);
  border-radius: 28rpx;
  padding: 28rpx 32rpx;
  box-shadow: var(--sh-2);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.vip-left { display: flex; align-items: center; gap: 16rpx; }
.vip-crown { font-size: 44rpx; }
.vip-title { display: block; font-size: 28rpx; font-weight: 700; color: #fff; }
.vip-sub   { display: block; font-size: 20rpx; color: rgba(255,255,255,0.7); margin-top: 4rpx; }

.vip-right { text-align: center; }
.vip-discount { display: block; font-size: 48rpx; font-weight: 800; color: #FFE07A; }
.vip-disc-label { display: block; font-size: 20rpx; color: rgba(255,255,255,0.7); }

/* 统计 */
.stats-row {
  margin: 20rpx 32rpx 0;
  background: #fff;
  border-radius: 28rpx;
  padding: 28rpx 0;
  box-shadow: var(--sh-1);
  display: flex;
  align-items: center;
}

.stat-item { flex: 1; text-align: center; }
.stat-num { display: block; font-size: 40rpx; font-weight: 700; color: var(--ink-900); font-variant-numeric: tabular-nums; }
.stat-label { display: block; font-size: 22rpx; color: var(--ink-500); margin-top: 6rpx; }
.stat-divider { width: 1rpx; height: 48rpx; background: var(--line-100); }

/* 菜单组 */
.menu-group {
  margin: 20rpx 32rpx 0;
  background: #fff;
  border-radius: 28rpx;
  box-shadow: var(--sh-1);
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid var(--line-100);
  position: relative;
}

.menu-item:last-child { border-bottom: none; }

.menu-icon { font-size: 36rpx; flex-shrink: 0; }
.menu-text { flex: 1; font-size: 30rpx; color: var(--ink-900); }
.menu-arrow { font-size: 36rpx; color: var(--ink-300); }
.menu-phone { font-size: 26rpx; color: var(--violet-500); font-weight: 600; }

.menu-badge {
  background: #B5503E;
  color: #fff;
  font-size: 18rpx;
  font-weight: 600;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  padding: 0 8rpx;
  border-radius: 999rpx;
}

.safe-footer { height: calc(140rpx + env(safe-area-inset-bottom)); }
