/* 栀·美研所 — 优惠券 */
.page { height: 100vh; background: #F5F3F9; }
.nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  background: #FFFFFF;
}
.nav-inner {
  height: 44px; display: flex; align-items: center; justify-content: center; position: relative;
}
.back-btn { position: absolute; left: 12rpx; width: 60rpx; height: 44px; display: flex; align-items: center; justify-content: center; }
.back-icon { font-size: 44rpx; color: #5A3F8A; }
.nav-title { font-size: 34rpx; font-weight: 600; color: #2B2640; }

/* 领券/我的券 切换 */
.mode-row { display: flex; padding: 8rpx 24rpx 16rpx; gap: 16rpx; }
.mode-btn {
  position: relative; font-size: 28rpx; color: #8B8699; padding: 8rpx 4rpx; font-weight: 500;
}
.mode-btn.active { color: #5A3F8A; font-weight: 700; }
.mode-btn.active::after {
  content: ''; position: absolute; left: 50%; bottom: -4rpx; transform: translateX(-50%);
  width: 40rpx; height: 4rpx; background: #5A3F8A; border-radius: 2rpx;
}
.mode-badge {
  background: #C8554E; color: #FFF; font-size: 18rpx; border-radius: 16rpx;
  padding: 0 8rpx; margin-left: 6rpx; vertical-align: middle;
}

/* 我的券状态 tab */
.my-tabs { display: flex; gap: 12rpx; margin-bottom: 20rpx; }
.my-tab {
  flex: 1; text-align: center; font-size: 24rpx; color: #8B8699;
  background: #FFFFFF; padding: 14rpx 0; border-radius: 12rpx;
}
.my-tab.active { background: #5A3F8A; color: #FFFFFF; font-weight: 600; }

.body { position: fixed; left: 0; right: 0; bottom: 0; padding: 24rpx; box-sizing: border-box; }

.empty { display: flex; flex-direction: column; align-items: center; padding-top: 160rpx; }
.empty-emoji { font-size: 100rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 30rpx; color: #6B6680; margin-bottom: 12rpx; }
.empty-sub { font-size: 24rpx; color: #A8A4B8; }

.coupon-card {
  display: flex; background: #FFFFFF; border-radius: 20rpx; margin-bottom: 24rpx;
  overflow: hidden; box-shadow: 0 4rpx 20rpx rgba(90, 63, 138, 0.06);
}
.coupon-left {
  width: 220rpx; flex-shrink: 0;
  background: linear-gradient(135deg, #5A3F8A, #7E5BB5);
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  color: #FFFFFF; padding: 36rpx 0;
}
.coupon-value { display: flex; align-items: baseline; }
.value-unit { font-size: 32rpx; font-weight: 600; }
.value-num { font-size: 72rpx; font-weight: 800; line-height: 1; }
.coupon-min { font-size: 22rpx; opacity: 0.85; margin-top: 12rpx; }

.coupon-divider { position: relative; width: 0; }
.notch { position: absolute; width: 24rpx; height: 24rpx; border-radius: 50%; background: #F5F3F9; left: -12rpx; }
.notch.top { top: -12rpx; }
.notch.bottom { bottom: -12rpx; }
.dash-line { position: absolute; top: 12rpx; bottom: 12rpx; border-left: 2rpx dashed #E5E1EE; }

.coupon-right { flex: 1; padding: 28rpx 28rpx; display: flex; flex-direction: column; }
.coupon-name { font-size: 30rpx; font-weight: 600; color: #2B2640; margin-bottom: 8rpx; }
.coupon-desc { font-size: 24rpx; color: #8B8699; margin-bottom: 8rpx; }
.coupon-expire { font-size: 22rpx; color: #A8A4B8; margin-bottom: 16rpx; }
.claim-btn {
  align-self: flex-end; margin-top: auto;
  background: #5A3F8A; color: #FFFFFF; font-size: 24rpx;
  padding: 10rpx 28rpx; border-radius: 30rpx;
}
.claim-btn.claimed { background: #C8C4D6; }

.coupon-card.disabled .coupon-left { background: #B8B2C8; }
.status-label {
  align-self: flex-end; margin-top: auto; font-size: 24rpx; color: #A8A4B8;
}
.status-label.avail { color: #5A3F8A; font-weight: 600; }
