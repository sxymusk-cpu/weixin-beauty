<!-- 栀·美研所 — 优惠券 -->
<view class="page">
  <view class="nav" style="padding-top: {{statusBarH}}px;">
    <view class="nav-inner">
      <view class="back-btn" bindtap="onBack"><text class="back-icon">‹</text></view>
      <text class="nav-title">优惠券</text>
    </view>
  </view>

  <scroll-view class="body" style="top: {{navH}}px;" scroll-y show-scrollbar="{{false}}">
    <view wx:if="{{!loading && list.length === 0}}" class="empty">
      <text class="empty-emoji">🎫</text>
      <text class="empty-text">暂无可用优惠券</text>
      <text class="empty-sub">关注门店活动，优惠不错过</text>
    </view>

    <view class="coupon-card" wx:for="{{list}}" wx:key="_id">
      <view class="coupon-left">
        <view class="coupon-value">
          <text class="value-unit">¥</text>
          <text class="value-num">{{item.value}}</text>
        </view>
        <text class="coupon-min" wx:if="{{item.min_amount > 0}}">满{{item.min_amount}}可用</text>
        <text class="coupon-min" wx:else>无门槛</text>
      </view>
      <view class="coupon-divider">
        <view class="notch top"></view>
        <view class="dash-line"></view>
        <view class="notch bottom"></view>
      </view>
      <view class="coupon-right">
        <text class="coupon-name">{{item.name}}</text>
        <text class="coupon-desc">{{item.desc}}</text>
        <text class="coupon-expire" wx:if="{{item.end_at}}">有效至 {{item.end_at}}</text>
        <view class="claim-btn" bindtap="onClaim" data-id="{{item._id}}">立即领取</view>
      </view>
    </view>

    <view style="height: 40rpx;"></view>
  </scroll-view>
</view>
