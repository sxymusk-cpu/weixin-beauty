/* 栀·美研所 — 首页 */

.page {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background: var(--bg-page);
}

/* ── 导航栏 ── */
.nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  background: var(--bg-page);
  z-index: 100;
}

.nav-inner {
  display: flex;
  align-items: center;
  height: 44px;
  padding: 0 32rpx;
}

.brand {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.brand-mark {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  background: var(--violet-500);
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.brand-name {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--ink-900);
  display: block;
  line-height: 1.2;
}

.brand-slogan {
  font-size: 20rpx;
  color: var(--ink-500);
  display: block;
  line-height: 1;
  margin-top: 4rpx;
}


/* ── 滚动区 ── */
.scroll-area {
  position: absolute;
  bottom: 0; left: 0; right: 0;
}

/* ── Hero 卡 ── */
.hero-card {
  margin: 24rpx 32rpx 0;
  background: #fff;
  border-radius: 36rpx;
  overflow: hidden;
  box-shadow: var(--sh-2);
}

/* 主视觉渐变区 */
.hero-banner {
  background: linear-gradient(135deg, var(--violet-500) 0%, #7B55B8 60%, #9B72D0 100%);
  padding: 40rpx 32rpx 36rpx;
}

.hero-banner-labels {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.hero-bl-tag {
  font-size: 22rpx;
  color: rgba(255,255,255,0.88);
  background: rgba(255,255,255,0.18);
  padding: 6rpx 20rpx;
  border-radius: 999rpx;
}

.hero-score-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.score-star  { font-size: 30rpx; color: #FFD166; }
.score-val   { font-size: 52rpx; font-weight: 700; color: #fff; line-height: 1; }
.score-count { font-size: 22rpx; color: rgba(255,255,255,0.75); }
.score-sep   { font-size: 22rpx; color: rgba(255,255,255,0.4); }
.score-dist  { font-size: 22rpx; color: rgba(255,255,255,0.75); }

.hero-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  padding: 24rpx 28rpx 0;
}

.hero-tag {
  font-size: 22rpx;
  font-weight: 500;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(90, 63, 138, 0.10);
  color: var(--violet-500);
}

.hero-tag--warn {
  background: rgba(194, 138, 42, 0.12);
  color: #C28A2A;
}

.hero-tag--plain {
  background: rgba(90, 63, 138, 0.05);
  color: var(--ink-500);
}

.hero-notice {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin: 20rpx 28rpx 24rpx;
  background: rgba(90, 63, 138, 0.06);
  border-radius: 16rpx;
  padding: 14rpx 20rpx;
}

.notice-icon { font-size: 28rpx; flex-shrink: 0; }

.notice-text {
  font-size: 24rpx;
  color: var(--ink-700);
  line-height: 1.4;
}

/* ── 三宫格 ── */
.tile-trio {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  padding: 24rpx 32rpx 0;
}

.tile {
  background: var(--white);
  border-radius: 28rpx;
  padding: 28rpx 16rpx;
  min-height: 110rpx;
  box-shadow: var(--sh-2);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  align-items: center;
}

.tile-primary { background: var(--violet-500); }

.tile-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--ink-900);
  text-align: center;
  display: block;
}

.tile-primary .tile-name { color: #fff; }

.tile-sub {
  font-size: 22rpx;
  color: var(--ink-500);
  text-align: center;
  display: block;
}

.tile-primary .tile-sub { color: rgba(255,255,255,0.72); }

/* ── 区块标题 ── */
.section-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  margin-top: 48rpx;
}

.section-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.section-bar {
  width: 8rpx;
  height: 36rpx;
  border-radius: 4rpx;
  background: var(--violet-500);
  flex-shrink: 0;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--ink-900);
}

.section-action {
  font-size: 24rpx;
  color: var(--ink-500);
}

/* ── 日期选择器 ── */
.date-scroll {
  margin-top: 16rpx;
  padding: 0 32rpx;
  white-space: nowrap;
}

.date-row {
  display: flex;
  gap: 16rpx;
  padding-bottom: 4rpx;
}

.date-chip {
  flex-shrink: 0;
  min-width: 100rpx;
  padding: 20rpx 16rpx;
  border-radius: 24rpx;
  background: var(--white);
  box-shadow: var(--sh-1);
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.date-chip--active {
  background: var(--violet-500);
}

.date-chip--full {
  opacity: 0.45;
}

.chip-week {
  font-size: 20rpx;
  color: var(--ink-500);
  display: block;
}

.date-chip--active .chip-week { color: rgba(255,255,255,0.8); }

.chip-date {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--ink-900);
  display: block;
  font-variant-numeric: tabular-nums;
}

.date-chip--active .chip-date { color: #fff; }

.chip-avail {
  font-size: 18rpx;
  color: var(--violet-500);
  display: block;
}

.date-chip--active .chip-avail { color: rgba(255,255,255,0.7); }

/* ── 服务网格 ── */
.service-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding: 20rpx 32rpx 0;
}

/* ── 底部 ── */
.safe-footer {
  height: calc(140rpx + env(safe-area-inset-bottom));
}
