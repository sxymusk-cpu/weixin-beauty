/* 栀·美研所 — 全部项目 */
.page { display: flex; flex-direction: column; height: 100vh; background: var(--bg-page); }

.cat-bar { flex-shrink: 0; white-space: nowrap; padding: 20rpx 32rpx; background: var(--bg-page); }
.cat-row { display: flex; gap: 12rpx; }

.cat-chip {
  display: inline-flex;
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 500;
  background: rgba(255,255,255,0.82);
  color: var(--ink-700);
  box-shadow: inset 0 0 0 1rpx var(--ink-100);
  flex-shrink: 0;
}

.cat-chip--active {
  background: var(--violet-500);
  color: #fff;
  box-shadow: none;
}

.grid-scroll { flex: 1; }

.service-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding: 8rpx 32rpx 0;
}

.safe-footer { height: 40rpx; }
