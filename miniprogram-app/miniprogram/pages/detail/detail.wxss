/* 栀·美研所 — 服务详情 */
.page { position: relative; height: 100vh; background: var(--bg-page); display: flex; flex-direction: column; }

/* 返回 */
.back-btn {
  position: fixed;
  top: calc(env(safe-area-inset-top) + 12rpx);
  left: 24rpx;
  width: 72rpx; height: 72rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.90);
  display: flex; align-items: center; justify-content: center;
  box-shadow: var(--sh-2);
  z-index: 200;
}

.back-icon { font-size: 48rpx; color: var(--ink-900); line-height: 1; margin-top: -4rpx; }

/* 封面 */
.cover {
  flex-shrink: 0;
  width: 100%;
  height: 480rpx;
  background: linear-gradient(160deg, #ece4f7 0%, #c9b8e8 100%);
  position: relative;
  display: flex; align-items: center; justify-content: center;
  overflow: hidden;
}

.cover-img { width: 100%; height: 100%; object-fit: cover; }
.cover-emoji-wrap { display: flex; align-items: center; justify-content: center; }
.cover-emoji { font-size: 160rpx; filter: drop-shadow(0 12rpx 20rpx rgba(0,0,0,0.10)); }

.cover-duration {
  position: absolute;
  bottom: 20rpx; right: 20rpx;
  background: rgba(255,255,255,0.92);
  color: var(--violet-500);
  font-size: 22rpx; font-weight: 600;
  padding: 8rpx 20rpx; border-radius: 999rpx;
}

/* 滚动 */
.detail-scroll { flex: 1; overflow: hidden; }

/* 信息卡 */
.info-card { background: #fff; padding: 28rpx 32rpx; margin-bottom: 16rpx; }

.tags { display: flex; flex-wrap: wrap; gap: 10rpx; margin-bottom: 16rpx; }
.tag { font-size: 20rpx; font-weight: 500; padding: 4rpx 16rpx; border-radius: 999rpx; }
.tag-primary { background: rgba(90,63,138,0.10); color: var(--violet-500); }
.tag-plain   { background: var(--bg-page); color: var(--ink-500); }

.service-name { font-size: 40rpx; font-weight: 700; color: var(--ink-900); display: block; line-height: 1.3; }

.price-row { display: flex; align-items: baseline; justify-content: space-between; margin-top: 20rpx; }
.price-group { display: flex; align-items: baseline; gap: 4rpx; color: var(--price); }
.yen { font-size: 24rpx; font-weight: 600; }
.price-num { font-size: 48rpx; font-weight: 700; font-variant-numeric: tabular-nums; }
.orig-price { font-size: 24rpx; color: var(--ink-300); text-decoration: line-through; margin-left: 8rpx; }
.rating { display: flex; align-items: baseline; }
.star { font-size: 24rpx; color: #E8A82B; }
.rating-num { font-size: 28rpx; font-weight: 600; color: var(--ink-700); margin-left: 4rpx; }
.review-cnt { font-size: 22rpx; color: var(--ink-400); }

/* 详情卡 */
.detail-card { background: #fff; padding: 28rpx 32rpx; margin-bottom: 16rpx; }

.section-hd { display: flex; align-items: center; gap: 16rpx; margin-bottom: 20rpx; }
.section-bar { width: 8rpx; height: 32rpx; border-radius: 4rpx; background: var(--violet-500); flex-shrink: 0; }
.section-title { font-size: 32rpx; font-weight: 700; color: var(--ink-900); }

.detail-text { font-size: 28rpx; color: var(--ink-700); line-height: 1.8; display: block; }

.notice-list { display: flex; flex-direction: column; gap: 16rpx; }
.notice-item { display: flex; gap: 12rpx; }
.dot { color: var(--violet-400); font-size: 28rpx; flex-shrink: 0; }
.notice-item text:last-child { font-size: 26rpx; color: var(--ink-700); line-height: 1.6; }

.safe-footer { height: calc(160rpx + env(safe-area-inset-bottom)); }

/* 底部操作栏 */
.action-bar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: #fff;
  border-top: 1rpx solid var(--line-100);
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  display: flex; align-items: center; gap: 20rpx;
  z-index: 100;
}

.fav-btn {
  display: flex; flex-direction: column; align-items: center; gap: 4rpx;
  padding: 0 20rpx;
}

.fav-icon { font-size: 44rpx; color: var(--violet-400); }
.fav-text { font-size: 18rpx; color: var(--ink-500); }

.book-btn {
  flex: 1;
  background: var(--violet-500);
  color: #fff;
  font-size: 30rpx; font-weight: 600;
  padding: 28rpx 0;
  border-radius: 999rpx;
  text-align: center;
}
