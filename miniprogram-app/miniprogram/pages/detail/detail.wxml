<!-- 栀·美研所 — 服务详情 -->
<view class="page" wx:if="{{service._id}}">

  <!-- 返回按钮 -->
  <view class="back-btn" bindtap="onBack">
    <text class="back-icon">‹</text>
  </view>

  <!-- 封面图 -->
  <view class="cover">
    <image wx:if="{{service.image}}" class="cover-img" src="{{service.image}}" mode="aspectFill" />
    <view wx:else class="cover-emoji-wrap">
      <text class="cover-emoji">{{service.emoji}}</text>
    </view>
    <view class="cover-duration">{{service.duration}} 分钟</view>
  </view>

  <scroll-view class="detail-scroll" scroll-y show-scrollbar="{{false}}">

    <!-- 基础信息 -->
    <view class="info-card">
      <view class="tags">
        <text wx:for="{{service.tags}}" wx:key="*this" class="tag {{index === 0 ? 'tag-primary' : 'tag-plain'}}">{{item}}</text>
      </view>
      <text class="service-name">{{service.name}}</text>
      <view class="price-row">
        <view class="price-group">
          <text class="yen">¥</text>
          <text class="price-num">{{service.price}}</text>
          <text wx:if="{{service.originalPrice}}" class="orig-price">¥{{service.originalPrice}}</text>
        </view>
        <view class="rating">
          <text class="star">★</text>
          <text class="rating-num">{{service.rating}}</text>
          <text class="review-cnt"> · {{service.reviewCount}} 评价</text>
        </view>
      </view>
    </view>

    <!-- 详细介绍 -->
    <view class="detail-card">
      <view class="section-hd">
        <view class="section-bar"></view>
        <text class="section-title">项目介绍</text>
      </view>
      <text class="detail-text">{{service.detail || service.desc}}</text>
    </view>

    <!-- 注意事项 -->
    <view class="detail-card">
      <view class="section-hd">
        <view class="section-bar"></view>
        <text class="section-title">注意事项</text>
      </view>
      <view class="notice-list">
        <view class="notice-item"><text class="dot">·</text><text>请提前 5 分钟到店，以便技师做准备</text></view>
        <view class="notice-item"><text class="dot">·</text><text>如有过敏史请提前告知技师</text></view>
        <view class="notice-item"><text class="dot">·</text><text>取消预约请提前 2 小时操作</text></view>
        <view class="notice-item"><text class="dot">·</text><text>项目时长含换衣和护理前准备时间</text></view>
      </view>
    </view>

    <view class="safe-footer"></view>
  </scroll-view>

  <!-- 底部操作栏 -->
  <view class="action-bar">
    <view class="fav-btn" bindtap="onFav">
      <text class="fav-icon">{{isFav ? '♥' : '♡'}}</text>
      <text class="fav-text">{{isFav ? '已收藏' : '收藏'}}</text>
    </view>
    <view class="book-btn" bindtap="onBook">
      <text>立即预约</text>
    </view>
  </view>

</view>
